<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Free Printable Braille Alphabet Chart (PDF) — BrailleLearn</title>
<meta name="description" content="Download a free printable Braille alphabet and numbers chart (PDF). Includes a dot-numbering guide, full A–Z reference and 0–9 numbers — ready to print.">
<link rel="canonical" href="https://braillelearn.co.uk/guides/braille-alphabet-printable.html">

<meta property="og:title" content="Free Printable Braille Alphabet Chart (PDF)">
<meta property="og:description" content="Download a free printable Braille alphabet and numbers chart — ready to print at home or in the classroom.">
<meta property="og:url" content="https://braillelearn.co.uk/guides/braille-alphabet-printable.html">
<meta property="og:type" content="article">
<meta property="og:image" content="https://braillelearn.co.uk/icon-512.png">

<script async src="https://www.googletagmanager.com/gtag/js?id=G-MVPLZ184M1"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-MVPLZ184M1');
</script>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0b14;--surface:#111320;--card:#161829;--card2:#1c1f35;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.11);
  --p:#7b6ef6;--p2:#a89df8;--p3:#5a4ecc;
  --g:#3ec99a;--y:#f5c842;--t1:#f0f2ff;--t2:#9498bb;--t3:#474a6a;
  --ff:'Outfit',sans-serif;--fm:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html{font-size:17px}
body{font-family:var(--ff);background:var(--bg);color:var(--t1);min-height:100vh;line-height:1.5}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

.btn{padding:14px 30px;border-radius:10px;font-size:16px;font-weight:700;font-family:var(--ff);cursor:pointer;transition:all .2s;border:none;display:inline-block;text-decoration:none}
.btn-p{background:var(--p);color:#fff}
.btn-p:hover{background:var(--p3);transform:translateY(-1px)}
.btn-o{background:var(--card);color:var(--t2);border:1px solid var(--border2)}

.land-nav{max-width:1200px;margin:0 auto;padding:22px 60px;display:flex;align-items:center;justify-content:space-between}
.brand{font-size:20px;font-weight:800;letter-spacing:-.5px;text-decoration:none;color:var(--t1)}
.brand b{color:var(--p)}
.land-nav-links{display:flex;gap:26px;align-items:center}
.land-nav-links a{color:var(--t2);text-decoration:none;font-size:14px;font-weight:600;transition:color .2s}
.land-nav-links a:hover{color:var(--t1)}
.nbtn{background:none;border:1px solid var(--border2);color:var(--t2);padding:9px 20px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;font-family:var(--ff);transition:all .2s;text-decoration:none}
.nbtn.fill{background:var(--p);color:#fff;border-color:var(--p)}
@media(max-width:800px){.land-nav-links{display:none}}

.wrap{max-width:780px;margin:0 auto;padding:56px 60px 100px}
.breadcrumb{font-size:13px;color:var(--t3);margin-bottom:20px}
.breadcrumb a{color:var(--t3);text-decoration:none}
.breadcrumb a:hover{color:var(--p2)}
.sec-lbl{font-size:12px;color:var(--p);font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px}
h1{font-size:clamp(30px,4vw,44px);font-weight:900;letter-spacing:-1.3px;line-height:1.12;margin-bottom:18px}
.lead{font-size:18px;color:var(--t2);line-height:1.75;margin-bottom:28px}
h2{font-size:21px;font-weight:800;letter-spacing:-.4px;margin:40px 0 14px}
p{font-size:15.5px;color:var(--t2);line-height:1.85;margin-bottom:15px}
ul,ol{margin:0 0 16px 22px;color:var(--t2);font-size:15.5px;line-height:1.85}
li{margin-bottom:6px}
a{color:var(--p2)}

.download-card{background:linear-gradient(135deg,rgba(123,110,246,.12),rgba(232,86,157,.06));border:1px solid rgba(123,110,246,.28);border-radius:20px;padding:32px;text-align:center;margin:32px 0 40px}
.dc-icon{font-size:44px;margin-bottom:12px}
.dc-title{font-size:20px;font-weight:800;margin-bottom:8px}
.dc-sub{font-size:14px;color:var(--t2);margin-bottom:22px}
.dc-meta{display:flex;justify-content:center;gap:20px;margin-top:18px;font-size:12px;color:var(--t3);flex-wrap:wrap}

.explorer{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:24px;margin:32px 0}
.explorer-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.explorer-title{font-size:14px;font-weight:800;color:var(--t1)}
.explorer-hint{font-size:12px;color:var(--t3)}
.explorer-tabs{display:flex;gap:6px;margin-bottom:16px}
.etab{background:none;border:1px solid var(--border2);color:var(--t2);padding:6px 14px;border-radius:8px;cursor:pointer;font-size:12px;font-weight:700;font-family:var(--ff);transition:all .2s}
.etab.on{background:var(--p);color:#fff;border-color:var(--p)}
.explorer-grid{display:grid;grid-template-columns:repeat(9,1fr);gap:8px}
.echar{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 4px;text-align:center;cursor:pointer;transition:all .15s}
.echar:hover{background:var(--card2);border-color:var(--border2);transform:translateY(-2px)}
.echar.active{border-color:var(--p);background:rgba(123,110,246,.1)}
.echar-l{font-size:14px;font-weight:800;color:var(--p2)}
.explorer-detail{margin-top:18px;padding-top:18px;border-top:1px solid var(--border);display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.ed-letter{font-size:48px;font-weight:900;color:var(--p);letter-spacing:-2px;min-width:56px}
.ed-dots{display:inline-grid;grid-template-columns:1fr 1fr;row-gap:4px;column-gap:12px;background:var(--card);border:2px solid var(--border2);border-radius:12px;padding:10px 12px}
.ed-dot{width:16px;height:16px;border-radius:50%;background:var(--card2)}
.ed-dot.on{background:var(--p);box-shadow:0 0 8px rgba(123,110,246,.5)}
.ed-info{font-size:13px;color:var(--t2);flex:1;min-width:180px}
.ed-info b{color:var(--t1)}
@media(max-width:600px){.explorer-grid{grid-template-columns:repeat(6,1fr)}}

.cta-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:26px;margin-top:44px;text-align:center}
.cta-box p{margin-bottom:16px}

.land-footer{padding:28px 0;border-top:1px solid var(--border);background:var(--bg);margin-top:20px}
.land-footer-inner{max-width:1200px;margin:0 auto;padding:0 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.footer-links{display:flex;gap:18px;flex-wrap:wrap}
.footer-links a{font-size:13px;color:var(--t3);text-decoration:none}
.footer-links a:hover{color:var(--p)}

@media(max-width:700px){
  .land-nav,.wrap,.land-footer-inner{padding-left:24px;padding-right:24px}
}
</style>
</head>
<body>

<nav class="land-nav">
  <a href="/" class="brand">Braille<b>Learn</b></a>
  <div class="land-nav-links">
    <a href="/about.html">About</a>
    <a href="/contact.html">Contact</a>
    <a href="/faq.html">FAQ</a>
  </div>
  <a class="nbtn fill" href="/#app">Start learning →</a>
</nav>

<div class="wrap">
  <div class="breadcrumb"><a href="/">Home</a> / Free Printable Braille Alphabet Chart</div>
  <div class="sec-lbl">Free printable · PDF</div>
  <h1>Free Printable Braille Alphabet & Numbers Chart</h1>
  <p class="lead">A clear, ready-to-print reference chart covering the full Braille alphabet (A–Z), numbers (0–9), and a simple guide to how Braille dots are numbered — free to download, print and share.</p>

  <div class="download-card">
    <div class="dc-icon">📄</div>
    <div class="dc-title">Download the printable chart</div>
    <div class="dc-sub">3 pages · A4 · Print-ready · No email required</div>
    <a href="/guides/braille-alphabet-chart.pdf" download class="btn btn-p">⬇ Download PDF chart — free</a>
    <div class="dc-meta">
      <span>📖 26 letters + 10 numbers</span>
      <span>🖨️ Optimised for black & white printing</span>
      <span>💜 Free, no sign-up</span>
    </div>
  </div>

  <!-- INTERACTIVE EXPLORER -->
  <div class="explorer">
    <div class="explorer-hd">
      <div class="explorer-title">🔤 Try it yourself — tap any letter or number</div>
      <div class="explorer-hint">Click a cell to see and hear its dot pattern</div>
    </div>
    <div class="explorer-tabs">
      <button class="etab on" id="etab-letters" onclick="switchExplorer('letters')">A–Z Letters</button>
      <button class="etab" id="etab-numbers" onclick="switchExplorer('numbers')">0–9 Numbers</button>
    </div>
    <div class="explorer-grid" id="explorer-grid"></div>
    <div class="explorer-detail" id="explorer-detail" style="display:none">
      <div class="ed-letter" id="ed-letter">A</div>
      <div class="ed-dots" id="ed-dots"></div>
      <div class="ed-info" id="ed-info"></div>
    </div>
  </div>

  <div class="download-card" id="worksheet-card">
    <div class="dc-icon">✏️</div>
    <div class="dc-title">Braille Practice Worksheet</div>
    <div class="dc-sub">8 pages · A4 · Blank tracing cells + "write your name" practice page</div>
    <div id="worksheet-locked">
      <p style="font-size:14px;color:var(--t2);max-width:440px;margin:0 auto 20px;line-height:1.7">This one's a Full Access perk — trace every letter A–Z with guided blank cells, plus a dedicated page to practise writing your own name in Braille.</p>
      <a href="https://buy.stripe.com/7sYcN5eB34cJ3fo5N92wU02" target="_blank" class="btn btn-p">🔓 Unlock with Full Access — £14.99/yr →</a>
      <div class="dc-meta">
        <span>✍️ Trace every letter A–Z</span>
        <span>💜 Plus all 6 lessons, quizzes & games</span>
        <span>🔓 Access unlocks instantly</span>
      </div>
    </div>
    <div id="worksheet-unlocked" style="display:none">
      <p style="font-size:14px;color:var(--g);margin-bottom:20px">✓ You have Full Access — enjoy the worksheet!</p>
      <a href="/guides/braille-practice-worksheet.pdf" download class="btn btn-p">⬇ Download practice worksheet</a>
    </div>
  </div>

  <h2>What's included</h2>
  <ul>
    <li><strong>Page 1 — How Braille dots are numbered.</strong> A simple diagram explaining the 6-dot cell layout, so the rest of the chart makes sense at a glance.</li>
    <li><strong>Page 2 — The full alphabet, A to Z</strong>, each letter shown with its dot pattern and the specific dot numbers used.</li>
    <li><strong>Page 3 — Numbers 0 to 9</strong>, using the same letter-based number system Braille readers rely on.</li>
  </ul>

  <h2>How to use this chart</h2>
  <ol>
    <li>Print it out — it's designed to look clear even on a basic black & white printer.</li>
    <li>Learn one row at a time rather than trying to memorise the whole alphabet at once.</li>
    <li>Say the letter name and its dot numbers out loud as you look at (or feel, if you have an embossed copy) each cell.</li>
    <li>Keep it somewhere visible — on a fridge, a classroom wall, or a study desk — for quick everyday reference.</li>
  </ol>

  <h2>Want more than a chart?</h2>
  <p>This printable is a quick reference, not a full teaching tool. For structured lessons that build up gradually, spoken memory tips for every letter, quizzes to check what's stuck, and games that make practice feel like play, BrailleLearn's interactive lessons are free to start.</p>

  <div class="cta-box">
    <p>Ready to go beyond the chart?</p>
    <a href="/#app" class="btn btn-p">Start the free interactive lessons →</a>
  </div>
</div>

<div class="land-footer">
  <div class="land-footer-inner">
    <a href="/" class="brand" style="font-size:16px">Braille<b>Learn</b></a>
    <div style="font-size:13px;color:var(--t3)">Built with 💜 for blind children and their families · braillelearn.co.uk</div>
    <div class="footer-links">
      <a href="/about.html">About</a>
      <a href="/contact.html">Contact</a>
      <a href="/faq.html">FAQ</a>
      <a href="/privacy.html">Privacy</a>
      <a href="/terms.html">Terms</a>
    </div>
  </div>
</div>
<script>
const BR = {
  a:{dots:[1],hint:'One dot, top left'}, b:{dots:[1,2],hint:'Two dots, left column top'},
  c:{dots:[1,4],hint:'Two dots, top row'}, d:{dots:[1,4,5],hint:'Three dots, top + mid right'},
  e:{dots:[1,5],hint:'Diagonal, top left to mid right'}, f:{dots:[1,2,4],hint:'Three dots, L shape'},
  g:{dots:[1,2,4,5],hint:'Four dots, top square'}, h:{dots:[1,2,5],hint:'Three dots, left top + mid right'},
  i:{dots:[2,4],hint:'Two dots, middle row'}, j:{dots:[2,4,5],hint:'Three dots, mid + right'},
  k:{dots:[1,3],hint:'Two dots, left column'}, l:{dots:[1,2,3],hint:'Full left column'},
  m:{dots:[1,3,4],hint:'Three dots, left + top right'}, n:{dots:[1,3,4,5],hint:'Four dots, left + right top'},
  o:{dots:[1,3,5],hint:'Three dots, diagonal stripe'}, p:{dots:[1,2,3,4],hint:'Four dots, two columns top'},
  q:{dots:[1,2,3,4,5],hint:'Five dots, almost full cell'}, r:{dots:[1,2,3,5],hint:'Four dots, left column + mid right'},
  s:{dots:[2,3,4],hint:'Three dots, inner square'}, t:{dots:[2,3,4,5],hint:'Four dots, lower square'},
  u:{dots:[1,3,6],hint:'Three dots, left column + bottom right'}, v:{dots:[1,2,3,6],hint:'Four dots, left column + bottom right'},
  w:{dots:[2,4,5,6],hint:'Four dots, right side heavy'}, x:{dots:[1,3,4,6],hint:'Four dots, cross pattern'},
  y:{dots:[1,3,4,5,6],hint:'Five dots, almost full right'}, z:{dots:[1,3,5,6],hint:'Four dots, diagonal corners'},
};
const NUM = {
  '1':[1],'2':[1,2],'3':[1,4],'4':[1,4,5],'5':[1,5],'6':[1,2,4],'7':[1,2,4,5],'8':[1,2,5],'9':[2,4],'0':[2,4,5]
};
let currentTab = 'letters';

function renderExplorerGrid(){
  const grid = document.getElementById('explorer-grid');
  const keys = currentTab === 'letters' ? Object.keys(BR) : Object.keys(NUM);
  grid.innerHTML = keys.map(k => `<div class="echar" id="ec-${k}" onclick="selectChar('${k}')"><div class="echar-l">${k.toUpperCase()}</div></div>`).join('');
}

function switchExplorer(tab){
  currentTab = tab;
  document.getElementById('etab-letters').classList.toggle('on', tab==='letters');
  document.getElementById('etab-numbers').classList.toggle('on', tab==='numbers');
  document.getElementById('explorer-detail').style.display = 'none';
  document.querySelectorAll('.echar').forEach(e=>e.classList.remove('active'));
  renderExplorerGrid();
}

function selectChar(k){
  document.querySelectorAll('.echar').forEach(e=>e.classList.remove('active'));
  document.getElementById('ec-'+k).classList.add('active');
  const dots = currentTab==='letters' ? BR[k].dots : NUM[k];
  const hint = currentTab==='letters' ? BR[k].hint : 'Same dot pattern as letter '+Object.keys(BR)[Object.keys(NUM).indexOf(k)]?.toUpperCase();
  document.getElementById('ed-letter').textContent = k.toUpperCase();
  document.getElementById('ed-dots').innerHTML = [1,2,3,4,5,6].map(d=>`<div class="ed-dot${dots.includes(d)?' on':''}"></div>`).join('');
  document.getElementById('ed-info').innerHTML = `<b>Dots: ${dots.join(', ')}</b><br>${currentTab==='letters' ? BR[k].hint : 'Number '+k+' — dots '+dots.join(', ')}`;
  document.getElementById('explorer-detail').style.display = 'flex';
  if(window.speechSynthesis){
    window.speechSynthesis.cancel();
    const name = currentTab==='letters' ? 'Letter '+k.toUpperCase() : 'Number '+k;
    const u = new SpeechSynthesisUtterance(`${name}. ${dots.length} dot${dots.length!==1?'s':''}. Dot ${dots.join(', ')}.`);
    u.rate = 0.9;
    window.speechSynthesis.speak(u);
  }
}

renderExplorerGrid();

// Check if this browser already has Full Access (same localStorage the main app uses)
(function checkMembership(){
  try{
    const s = JSON.parse(localStorage.getItem('bl4')||'{}');
    if(s.member===true){
      document.getElementById('worksheet-locked').style.display='none';
      document.getElementById('worksheet-unlocked').style.display='block';
    }
  }catch(e){}
})();
</script>

</body>
</html>
